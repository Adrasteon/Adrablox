{
  "name": "vscode-adrablox-control",
  "displayName": "Adrablox Control",
  "description": "Click-first VS Code controls for Adrablox MCP workflows",
  "version": "0.0.1",
  "publisher": "adrasteon",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:adrablox.status",
    "onView:adrablox.workspaceTree",
    "onView:adrablox.actions",
    "onView:adrablox.taskOutput",
    "onCommand:adrablox.check.connectVerify",
    "onCommand:adrablox.check.fullHealth",
    "onCommand:adrablox.session.open",
    "onCommand:adrablox.session.readTree",
    "onCommand:adrablox.workspace.setActiveTarget",
    "onCommand:adrablox.session.subscribeOnce",
    "onCommand:adrablox.snapshot.export",
    "onCommand:adrablox.snapshot.import",
    "onCommand:adrablox.sync.smokeTest",
    "onCommand:adrablox.task.rerun"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adrablox",
          "title": "Adrablox",
          "icon": "media/adrablox.svg"
        }
      ]
    },
    "views": {
      "adrablox": [
        {
          "id": "adrablox.status",
          "name": "Status"
        },
        {
          "id": "adrablox.workspaceTree",
          "name": "Workspace Tree"
        },
        {
          "id": "adrablox.actions",
          "name": "Actions"
        },
        {
          "id": "adrablox.taskOutput",
          "name": "Task Output"
        }
      ]
    },
    "commands": [
      {
        "command": "adrablox.check.connectVerify",
        "title": "Adrablox: Connect Verify"
      },
      {
        "command": "adrablox.check.fullHealth",
        "title": "Adrablox: Full Health Check"
      },
      {
        "command": "adrablox.session.open",
        "title": "Adrablox: Open Session"
      },
      {
        "command": "adrablox.session.readTree",
        "title": "Adrablox: Read Tree"
      },
      {
        "command": "adrablox.workspace.setActiveTarget",
        "title": "Adrablox: Set Active Target"
      },
      {
        "command": "adrablox.session.subscribeOnce",
        "title": "Adrablox: Subscribe Once"
      },
      {
        "command": "adrablox.snapshot.export",
        "title": "Adrablox: Export Snapshot"
      },
      {
        "command": "adrablox.snapshot.import",
        "title": "Adrablox: Import Snapshot"
      },
      {
        "command": "adrablox.sync.smokeTest",
        "title": "Adrablox: Run Smoke Test"
      },
      {
        "command": "adrablox.task.rerun",
        "title": "Adrablox: Rerun Task"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "adrablox.workspace.setActiveTarget",
          "when": "view == adrablox.workspaceTree && viewItem == adrablox.workspaceNode",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Adrablox",
      "properties": {
        "adrablox.transport.mode": {
          "type": "string",
          "enum": [
            "rpc-first",
            "script-only"
          ],
          "default": "rpc-first",
          "description": "Transport strategy for core session actions. rpc-first uses direct MCP JSON-RPC with optional script fallback."
        },
        "adrablox.transport.enableFallback": {
          "type": "boolean",
          "default": true,
          "description": "When enabled in rpc-first mode, failed RPC calls fall back to existing PowerShell script actions."
        },
        "adrablox.transport.endpoint": {
          "type": "string",
          "default": "http://127.0.0.1:44877/mcp",
          "description": "MCP HTTP JSON-RPC endpoint used by direct RPC transport."
        },
        "adrablox.session.projectPath": {
          "type": "string",
          "default": "adrablox.project.json",
          "description": "Project path sent to roblox.openSession when using direct RPC transport."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.3"
  }
}